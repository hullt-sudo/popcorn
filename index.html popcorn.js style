      {phase==="shaking"&&<div style={{fontSize:96,animation:"chestShake .12s infinite"}}>{isWin?"🏆":"🎁"}</div>}

      {phase==="reveal"&&reward&&rar&&<div style={{display:"flex",flexDirection:"column",alignItems:"center",gap:16,animation:"popIn .6s ease"}}>
        <div style={{background:`radial-gradient(circle,${rar.bg},#0d0d0d 75%)`,border:`3px solid ${rar.color}`,borderRadius:24,padding:"24px 44px",boxShadow:`0 0 50px ${rar.glow}66`,textAlign:"center",position:"relative"}}>

          {/* Dupe badge — top-right corner */}
