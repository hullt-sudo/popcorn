// ─── SAVE / LOAD — MULTI-ACCOUNT WITH PIN ─────────────────────
const ACCOUNTS_KEY = "popcornbattle_accounts_v1";  // stores all user accounts
const SESSION_KEY  = "popcornbattle_session_v1";   // stores who is currently logged in

function loadAccounts(){
  try{ return JSON.parse(localStorage.getItem(ACCOUNTS_KEY)||"{}"); }
  catch(e){ return {}; }
}
function saveAccounts(accounts){
  try{ localStorage.setItem(ACCOUNTS_KEY,JSON.stringify(accounts)); }catch(e){}
}
function loadSession(){
  try{ return JSON.parse(localStorage.getItem(SESSION_KEY)||"null"); }
  catch(e){ return null; }
}
function saveSession(username){
  try{ localStorage.setItem(SESSION_KEY,JSON.stringify(username)); }catch(e){}
}
function clearSession(){
  try{ localStorage.removeItem(SESSION_KEY); }catch(e){}
}
function getAccount(username){
  const accounts=loadAccounts();
  return accounts[username.toLowerCase()]||null;
}
function createAccount(username, pin){
  const accounts=loadAccounts();
  const key=username.toLowerCase();
  accounts[key]={ username, pin, unlockedKernelIds:[KERNELS[0].id], selectedKernelId:KERNELS[0].id, selectedAbility:"shield", gameMode:"solo" };
  saveAccounts(accounts);
  return accounts[key];
}
function updateAccount(username, data){
  const accounts=loadAccounts();
  const key=username.toLowerCase();
  if(accounts[key]) accounts[key]={...accounts[key],...data};
  saveAccounts(accounts);
}

// ─── MAIN APP ─────────────────────────────────────────────────
export default function PopcornBattle(){
  // ── load session (who was last logged in)
  const sessionUser = loadSession();
  const sessionAccount = sessionUser ? getAccount(sessionUser) : null;

  const[screen,setScreen]=useState(sessionAccount ? "lobby" : "login");
  const[username,setUsername]=useState(sessionAccount?.username||"");
  const[usernameInput,setUsernameInput]=useState("");
  const[pinInput,setPinInput]=useState("");         // 4-digit PIN entry
  const[loginMode,setLoginMode]=useState("new");   // "new" | "returning"
  const[roomCode,setRoomCode]=useState("");
  const[roomInput,setRoomInput]=useState("");
  const[gameMode,setGameMode]=useState(sessionAccount?.gameMode||"solo");
  const[selectedKernel,setSelectedKernel]=useState(()=>{
    if(sessionAccount?.selectedKernelId) return KERNELS.find(k=>k.id===sessionAccount.selectedKernelId)||KERNELS[0];
    return KERNELS[0];
  });
  const[selectedAbility,setSelectedAbility]=useState(sessionAccount?.selectedAbility||"shield");
  const[unlockedKernels,setUnlockedKernels]=useState(()=>{
    if(sessionAccount?.unlockedKernelIds?.length)
      return sessionAccount.unlockedKernelIds.map(id=>KERNELS.find(k=>k.id===id)||KERNELS[0]);
    return [KERNELS[0]];
  });
  const[showCollection,setShowCollection]=useState(false);
  const[error,setError]=useState("");
  const[countdown,setCountdown]=useState(null);
  const[lobbyBots,setLobbyBots]=useState([]);
  const[placement,setPlacement]=useState(60);

  // ── auto-save to account whenever anything changes
  useEffect(()=>{
    if(!username) return;
    updateAccount(username,{
      gameMode,
      selectedKernelId: selectedKernel.id,
      selectedAbility,
      unlockedKernelIds: unlockedKernels.map(k=>k.id),
    });
  },[username,gameMode,selectedKernel,selectedAbility,unlockedKernels]);

  function buildLobby(mode){const m=GAME_MODES.find(x=>x.id===mode);setLobbyBots(Array.from({length:m.teamSize-1},()=>({name:rndBotName(),k:rndKernel()})));}

  // Build lobby on first render if session exists
  useEffect(()=>{ if(sessionAccount) buildLobby(sessionAccount.gameMode||"solo"); },[]);

  function handleLogin(){
    const uname=usernameInput.trim();
    if(!uname){setError("Enter a username!");return;}
    if(pinInput.length!==4||!/^\d{4}$/.test(pinInput)){setError("PIN must be exactly 4 digits!");return;}

    const existing=getAccount(uname);
    if(loginMode==="returning"){
      if(!existing){setError("Account not found. Switch to New Account.");return;}
      if(existing.pin!==pinInput){setError("Wrong PIN!");return;}
      // Login success — load their data
      setUsername(existing.username);
      setUnlockedKernels(existing.unlockedKernelIds.map(id=>KERNELS.find(k=>k.id===id)||KERNELS[0]));
      setSelectedKernel(KERNELS.find(k=>k.id===existing.selectedKernelId)||KERNELS[0]);
      setSelectedAbility(existing.selectedAbility||"shield");
      setGameMode(existing.gameMode||"solo");
      saveSession(existing.username);
      setScreen("lobby");
      buildLobby(existing.gameMode||"solo");
      setError("");
    } else {
      if(existing){setError("Username taken! Switch to Returning Player.");return;}
      const acct=createAccount(uname,pinInput);
      setUsername(acct.username);
      saveSession(acct.username);
      setScreen("lobby");
      buildLobby("solo");
      setError("");
    }
  }

  function handleLogout(){
    clearSession();
    setUsername(""); setUsernameInput(""); setPinInput("");
    setScreen("login"); setLoginMode("new");
  }
  function handleCreate(){setRoomCode(genCode());setError("");buildLobby(gameMode);}
  function handleJoin(){if(!roomInput.trim()){setError("Enter a room code!");return;}setRoomCode(roomInput.trim().toUpperCase());setError("");buildLobby(gameMode);}

  useEffect(()=>{
    if(countdown===null)return;
    if(countdown===0){setScreen("ability");setCountdown(null);return;}
    const t=setTimeout(()=>setCountdown(c=>c-1),1000);return()=>clearTimeout(t);
  },[countdown]);

  function handleGameEnd(place){ setPlacement(place||60); setScreen("chest"); }
  function handleClaim(k){
    // Always add — dupes are allowed, collection tracks how many copies
    setUnlockedKernels(p=>[...p,k]);
    setScreen("lobby");
    buildLobby(gameMode);
  }
  const S={fontFamily:"'Courier New',monospace",color:"#fff"};

  if(screen==="login") return(
    <div style={{...S,minHeight:"100vh",background:"radial-gradient(ellipse at 50% 30%,#3d1a00,#0d0500)",display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",padding:24}}>
      <div style={{fontSize:70,filter:"drop-shadow(0 0 30px #FFD700)",marginBottom:4}}>🍿</div>
      <div style={{fontSize:27,fontWeight:900,color:"#FFD700",textShadow:"0 0 30px #FFD700",letterSpacing:4,marginBottom:6}}>POPCORN BATTLE</div>
      <div style={{color:"#777",fontSize:12,letterSpacing:3,marginBottom:32}}>60-PLAYER BATTLE ROYALE</div>

      {/* New / Returning toggle */}
      <div style={{display:"flex",gap:0,marginBottom:24,border:"1px solid rgba(255,165,0,.3)",borderRadius:10,overflow:"hidden"}}>
        {["new","returning"].map(mode=>(
          <button key={mode} onClick={()=>{setLoginMode(mode);setError("");}}
            style={{padding:"9px 24px",fontSize:12,fontWeight:700,letterSpacing:1,cursor:"pointer",fontFamily:"monospace",border:"none",
              background:loginMode===mode?"rgba(255,165,0,.22)":"transparent",
              color:loginMode===mode?"#FFD700":"#555",transition:"all .15s"}}>
            {mode==="new"?"✨ NEW ACCOUNT":"🔑 RETURNING"}
          </button>
        ))}
      </div>

      <div style={{background:"rgba(255,255,255,.04)",border:"1px solid rgba(255,165,0,.25)",borderRadius:18,padding:"28px 36px",display:"flex",flexDirection:"column",gap:12,minWidth:300,maxWidth:360,width:"100%"}}>
        <div style={{fontSize:11,color:"#555",letterSpacing:1,marginBottom:2}}>
          {loginMode==="new" ? "Create your account" : "Welcome back!"}
        </div>

        <input value={usernameInput} onChange={e=>setUsernameInput(e.target.value)}
          onKeyDown={e=>e.key==="Enter"&&handleLogin()}
          placeholder="Username..." maxLength={16}
          style={{background:"rgba(255,255,255,.07)",border:"1px solid rgba(255,165,0,.35)",borderRadius:10,padding:"11px 14px",color:"#fff",fontSize:15,fontFamily:"monospace",outline:"none"}}/>

        {/* PIN input — 4 digit boxes */}
        <div>
          <div style={{fontSize:11,color:"#666",marginBottom:6,letterSpacing:1}}>4-DIGIT PIN</div>
          <div style={{display:"flex",gap:8,justifyContent:"center"}}>
            {[0,1,2,3].map(i=>(
              <div key={i} style={{width:44,height:52,background:"rgba(255,255,255,.06)",border:`1px solid ${pinInput.length>i?"rgba(255,165,0,.6)":"rgba(255,255,255,.1)"}`,borderRadius:10,display:"flex",alignItems:"center",justifyContent:"center",fontSize:22,color:"#FFD700",fontWeight:700,transition:"border-color .15s"}}>
                {pinInput[i] ? "●" : ""}
              </div>
            ))}
          </div>
          {/* Hidden input for PIN */}
          <input
            value={pinInput}
            onChange={e=>{ const v=e.target.value.replace(/\D/g,"").slice(0,4); setPinInput(v); }}
            onKeyDown={e=>e.key==="Enter"&&handleLogin()}
            type="tel" inputMode="numeric" maxLength={4}
            placeholder="tap to enter PIN"
            style={{marginTop:8,width:"100%",background:"rgba(255,255,255,.05)",border:"1px solid rgba(255,255,255,.1)",borderRadius:8,padding:"8px 12px",color:"#aaa",fontFamily:"monospace",fontSize:13,outline:"none",textAlign:"center",letterSpacing:4}}/>
        </div>

        {error&&<div style={{color:"#FF4444",fontSize:12,textAlign:"center"}}>{error}</div>}

        <button onClick={handleLogin} style={{background:"linear-gradient(135deg,#FFD700,#FF8C00)",color:"#1a0000",border:"none",borderRadius:12,padding:13,fontSize:15,fontWeight:900,cursor:"pointer",fontFamily:"monospace",letterSpacing:2,marginTop:4}}>
          {loginMode==="new"?"🍿 CREATE & PLAY":"🍿 LOG IN"}
        </button>

        <div style={{fontSize:10,color:"#333",textAlign:"center",marginTop:2}}>
          {loginMode==="new"?"Your PIN keeps your collection safe across sessions.":"Your username and PIN restore your full collection."}
        </div>
      </div>
    </div>
  );

  if(screen==="lobby") return(
    <div style={{...S,minHeight:"100vh",background:"radial-gradient(ellipse at 50% 0%,#1a0033,#0d0500)",display:"flex",flexDirection:"column",alignItems:"center",padding:16}}>
      <div style={{display:"flex",alignItems:"center",gap:12,marginBottom:16,marginTop:8,flexWrap:"wrap",justifyContent:"center"}}>
        <div style={{fontSize:20,fontWeight:900,color:"#FFD700"}}>🍿 {username}</div>
        {roomCode&&<div style={{background:"rgba(255,215,0,.12)",border:"1px solid #FFD700",borderRadius:8,padding:"3px 14px",fontSize:17,fontWeight:900,color:"#FFD700",letterSpacing:4}}>{roomCode}</div>}
        <button onClick={()=>setShowCollection(true)} style={{background:"rgba(255,255,255,.06)",border:"1px solid #555",color:"#aaa",borderRadius:8,padding:"5px 12px",fontSize:12,cursor:"pointer",fontFamily:"monospace"}}>📚 Collection</button>
        <div style={{fontSize:10,color:"#2a6",background:"rgba(0,200,80,.06)",border:"1px solid rgba(0,200,80,.2)",borderRadius:6,padding:"3px 10px",letterSpacing:1}}>💾 Saved</div>
        <button onClick={handleLogout} style={{background:"rgba(255,100,50,.08)",border:"1px solid rgba(255,100,50,.3)",color:"#FF8866",borderRadius:6,padding:"3px 10px",fontSize:10,cursor:"pointer",fontFamily:"monospace"}}>⬅ Log Out</button>
      </div>
      <div style={{display:"flex",gap:16,flexWrap:"wrap",justifyContent:"center",width:"100%",maxWidth:820}}>
        <div style={{background:"rgba(255,255,255,.04)",border:"1px solid rgba(255,165,0,.2)",borderRadius:14,padding:"18px 20px",flex:"1 1 200px",minWidth:200}}>
          <div style={{fontSize:11,color:"#888",marginBottom:10,fontWeight:700,letterSpacing:2}}>ROOM</div>
          <div style={{display:"flex",flexDirection:"column",gap:8}}>
            <button onClick={handleCreate} style={{background:"rgba(255,165,0,.12)",border:"1px solid #FFA500",color:"#FFA500",borderRadius:8,padding:10,cursor:"pointer",fontFamily:"monospace",fontWeight:700}}>+ Create Room</button>
            <div style={{display:"flex",gap:6}}>
              <input value={roomInput} onChange={e=>setRoomInput(e.target.value)} placeholder="Room code..." maxLength={8} style={{flex:1,background:"rgba(255,255,255,.07)",border:"1px solid #444",borderRadius:8,padding:8,color:"#fff",fontFamily:"monospace",fontSize:13,outline:"none"}}/>
              <button onClick={handleJoin} style={{background:"rgba(100,200,100,.12)",border:"1px solid #66BB6A",color:"#66BB6A",borderRadius:8,padding:"8px 10px",cursor:"pointer",fontFamily:"monospace",fontWeight:700}}>Go</button>
            </div>
            {error&&<div style={{color:"#FF4444",fontSize:11}}>{error}</div>}
          </div>
        </div>
        <div style={{background:"rgba(255,255,255,.04)",border:"1px solid rgba(255,165,0,.2)",borderRadius:14,padding:"18px 20px",flex:"1 1 180px",minWidth:180}}>
          <div style={{fontSize:11,color:"#888",marginBottom:10,fontWeight:700,letterSpacing:2}}>GAME MODE</div>
          {GAME_MODES.map(m=><button key={m.id} onClick={()=>{setGameMode(m.id);buildLobby(m.id);}} style={{display:"block",width:"100%",marginBottom:6,background:gameMode===m.id?"rgba(255,165,0,.18)":"transparent",border:`1px solid ${gameMode===m.id?"#FFA500":"#333"}`,color:gameMode===m.id?"#FFA500":"#777",borderRadius:8,padding:"7px 10px",cursor:"pointer",fontFamily:"monospace",fontSize:13,textAlign:"left"}}>{m.icon} {m.label} <span style={{opacity:.4,fontSize:11}}>({m.teamSize}p)</span></button>)}
        </div>
        <div style={{background:"rgba(255,255,255,.04)",border:"1px solid rgba(255,165,0,.2)",borderRadius:14,padding:"18px 20px",flex:"1 1 220px",minWidth:220}}>
          <div style={{fontSize:11,color:"#888",marginBottom:10,fontWeight:700,letterSpacing:2}}>KERNEL ({unlockedKernels.length}/{KERNELS.length})</div>
          <div style={{display:"flex",flexWrap:"wrap",gap:6,maxHeight:140,overflowY:"auto"}}>
            {unlockedKernels.map(k=>{const rar=RARITY[k.rarity];return <button key={k.id} onClick={()=>setSelectedKernel(k)} title={`${k.name} (${rar.label})`} style={{background:selectedKernel.id===k.id?rar.bg:"rgba(255,255,255,.05)",border:`2px solid ${selectedKernel.id===k.id?rar.color:"#333"}`,borderRadius:10,padding:"6px 8px",cursor:"pointer",fontSize:20,boxShadow:selectedKernel.id===k.id?`0 0 12px ${rar.glow}88`:"none"}}>{k.emoji}</button>;})}
          </div>
          <div style={{fontSize:11,color:RARITY[selectedKernel.rarity].color,marginTop:8}}>{selectedKernel.name} — {RARITY[selectedKernel.rarity].label}</div>
        </div>
      </div>
      {lobbyBots.length>0&&<div style={{background:"rgba(255,255,255,.03)",border:"1px solid rgba(255,165,0,.15)",borderRadius:12,padding:"14px 20px",marginTop:16,minWidth:240}}>
        <div style={{fontSize:11,color:"#888",marginBottom:8,fontWeight:700,letterSpacing:2}}>YOUR TEAM</div>
        <div style={{display:"flex",flexDirection:"column",gap:5}}>
          <div style={{display:"flex",gap:8,alignItems:"center",fontSize:13}}><span>👤</span><span style={{color:"#fff"}}>{username}</span><span style={{fontSize:10,color:"#FFD700",background:"rgba(255,215,0,.1)",borderRadius:4,padding:"1px 6px"}}>YOU</span></div>
          {lobbyBots.map((b,i)=><div key={i} style={{display:"flex",gap:8,alignItems:"center",fontSize:13}}><span>{b.k.emoji}</span><span style={{color:"#555"}}>{b.name}</span></div>)}
        </div>
      </div>}
      {countdown!==null
        ?<div style={{fontSize:80,fontWeight:900,color:"#FFD700",textShadow:"0 0 40px #FFD700",marginTop:20}}>{countdown||"🍿"}</div>
        :<button onClick={()=>setCountdown(3)} disabled={!roomCode} style={{marginTop:20,background:roomCode?"linear-gradient(135deg,#FFD700,#FF8C00)":"#333",color:roomCode?"#1a0000":"#666",border:"none",borderRadius:14,padding:"15px 48px",fontSize:17,fontWeight:900,cursor:roomCode?"pointer":"not-allowed",fontFamily:"monospace",letterSpacing:2}}>{roomCode?"🍿 START GAME!":"Create or Join a Room first"}</button>}
      {showCollection&&<CollectionScreen unlockedKernels={unlockedKernels} onClose={()=>setShowCollection(false)}/>}
    </div>
  );

  if(screen==="ability") return(
    <div style={{...S,minHeight:"100vh",background:"radial-gradient(ellipse,#0d0033,#0d0500)",display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",padding:24}}>
      <div style={{fontSize:22,fontWeight:900,color:"#FFD700",marginBottom:4}}>Choose Your Ability</div>
      <div style={{color:"#555",fontSize:12,marginBottom:28,letterSpacing:1}}>DODGE the boss! Move around the frying pan to survive.</div>
      <div style={{display:"flex",gap:8,marginBottom:22,flexWrap:"wrap",justifyContent:"center"}}>
        {BOSSES.map((b,i)=><div key={b.id} style={{textAlign:"center",padding:"8px 12px",background:"rgba(255,255,255,.04)",borderRadius:10,border:`1px solid ${b.color}44`}}>
          <div style={{fontSize:28}}>{b.icon}</div>
          <div style={{fontSize:9,color:b.color,marginTop:4}}>Boss {i+1}</div>
          <div style={{fontSize:8,color:"#555"}}>4 phases</div>
        </div>)}
      </div>
      <div style={{display:"flex",gap:16,flexWrap:"wrap",justifyContent:"center",marginBottom:36}}>
        {ABILITIES.map(a=><div key={a.id} onClick={()=>setSelectedAbility(a.id)} style={{background:selectedAbility===a.id?"rgba(255,255,255,.1)":"rgba(255,255,255,.03)",border:`2px solid ${selectedAbility===a.id?a.color:"#333"}`,borderRadius:18,padding:"22px 26px",cursor:"pointer",textAlign:"center",minWidth:140,boxShadow:selectedAbility===a.id?`0 0 24px ${a.color}55`:"none",transition:"all .2s"}}>
          <div style={{fontSize:40,marginBottom:10}}>{a.icon}</div>
          <div style={{fontSize:15,fontWeight:700,color:selectedAbility===a.id?a.color:"#ddd"}}>{a.name}</div>
          <div style={{fontSize:11,color:"#666",marginTop:6}}>{a.desc}</div>
        </div>)}
      </div>
      <button onClick={()=>setScreen("game")} style={{background:"linear-gradient(135deg,#FFD700,#FF8C00)",color:"#1a0000",border:"none",borderRadius:14,padding:"14px 48px",fontSize:16,fontWeight:900,cursor:"pointer",fontFamily:"monospace",letterSpacing:2}}>🍿 ENTER THE PAN</button>
    </div>
  );

  if(screen==="game") return(
    <div style={{...S,minHeight:"100vh",background:"#080400",display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",padding:8}}>
      <GameCanvas key={Date.now()} playerKernel={selectedKernel} ability={selectedAbility} gameMode={gameMode} onGameEnd={handleGameEnd}/>
    </div>
  );

  if(screen==="chest") return <ChestScreen unlockedKernels={unlockedKernels} placement={placement} onClaim={handleClaim}/>;

  if(screen==="gameOver"){ handleClaim(rollChest()); return null; } // shouldn't reach here anymore

  return null;
}
